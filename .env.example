# =============================================================================
# YEZZ monorepo — copy to .env (root) and/or per-app .env.local as needed.
# Never commit real secrets. Values below are development placeholders only.
# =============================================================================

# --- apps/api ---
DATABASE_URL=postgres://yezz:yezz@localhost:5432/yezz
REDIS_URL=redis://localhost:6379
PORT=4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
NODE_ENV=development

# --- apps/web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_USE_API=false

# Phase 2 删除前仍需要（首页等 fallback）
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# --- packages/db (migrate / seed) ---
# DATABASE_URL=postgres://yezz:yezz@localhost:5432/yezz

# --- seed (packages/db, P1) ---
ADMIN_EMAIL=admin@yezz.local
ADMIN_PASSWORD=changeme

# --- optional (booking / cart emails, existing web) ---
RESEND_API_KEY=
OWNER_EMAIL=
