{
  "name": "yezz",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @yezz/web dev",
    "dev:web": "pnpm --filter @yezz/web dev",
    "dev:api": "pnpm --filter @yezz/api dev",
    "build": "pnpm --filter @yezz/web build",
    "start": "pnpm --filter @yezz/web start",
    "lint": "pnpm --filter @yezz/web lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "db:generate": "pnpm --filter @yezz/db generate",
    "db:migrate": "pnpm --filter @yezz/db migrate",
    "db:seed": "pnpm --filter @yezz/db seed",
    "test:api": "pnpm --filter @yezz/api test",
    "test:e2e": "pnpm --filter @yezz/web test:e2e",
    "test:e2e:ui": "pnpm --filter @yezz/web test:e2e:ui",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "packageManager": "pnpm@10.12.1"
}
